<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent">

    <!-- EBENE 1: Der normale Foto-Inhalt (Wird im Onboarding versteckt) -->
    <LinearLayout
        android:id="@+id/layout_fotos_content"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Custom Top Tab Bar & Top Selection Bar -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:elevation="4dp">

            <LinearLayout
                android:id="@+id/layout_top_tabs"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="8dp"
                android:paddingTop="16dp"
                android:paddingBottom="8dp"
                android:gravity="center"
                android:background="#FFFFFF">

                <TextView android:id="@+id/tab_fotos" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Fotos" android:textAlignment="center" android:paddingVertical="8dp" android:textColor="#555555" />
                <TextView android:id="@+id/tab_suche" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Suche" android:textAlignment="center" android:paddingVertical="8dp" android:textColor="#555555" />
                <TextView android:id="@+id/tab_alben" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Alben" android:textAlignment="center" android:paddingVertical="8dp" android:textColor="#555555" />
                <TextView android:id="@+id/tab_bibliothek" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Bibliothek" android:textAlignment="center" android:paddingVertical="8dp" android:textColor="#555555" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/layout_selection_bar"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="16dp"
                android:background="#8CA8B3"
                android:visibility="gone">

                <TextView
                    android:id="@+id/btn_close_selection"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✕"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:padding="8dp" />

                <TextView
                    android:id="@+id/tv_selection_count"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="1 ausgewählt"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:layout_marginStart="16dp" />
            </LinearLayout>
        </FrameLayout>

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <!-- 1. FOTOS Container (NEU: Beinhaltet nun Memories und das Grid) -->
            <LinearLayout
                android:id="@+id/layout_fotos_main"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:visibility="visible">

                <!-- Die neue Google-Fotos mäßige Erinnerungsleiste -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recycler_view_memories"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingTop="8dp"
                    android:paddingBottom="4dp"
                    android:clipToPadding="false"
                    android:visibility="gone" />

                <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
                    android:id="@+id/swipe_refresh_layout"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1">

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/recycler_view_fotos"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:clipToPadding="false"
                        android:paddingBottom="100dp"
                        android:visibility="visible"/>
                </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>
            </LinearLayout>

            <!-- 2. SUCHE (RAM-sicher, kein NestedScrollView für RecyclerView) -->
            <LinearLayout
                android:id="@+id/layout_search"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:visibility="gone">

                <EditText
                    android:id="@+id/et_search_input"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_margin="16dp"
                    android:background="@drawable/bg_pill_selected"
                    android:backgroundTint="#FFFFFF"
                    android:elevation="2dp"
                    android:hint="🔍 Fotos, Orte, Personen..."
                    android:imeOptions="actionSearch"
                    android:inputType="text"
                    android:paddingHorizontal="16dp"
                    android:textColor="#333333"
                    android:textColorHint="#888888" />

                <TextView
                    android:id="@+id/tv_search_loading"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="KI durchsucht Cloud..."
                    android:textAlignment="center"
                    android:textColor="#888888"
                    android:visibility="gone" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recycler_view_search"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:clipToPadding="false"
                    android:paddingBottom="100dp"
                    android:visibility="gone" />

                <ScrollView
                    android:id="@+id/layout_search_scrollable_menus"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingBottom="100dp">

                        <LinearLayout
                            android:id="@+id/layout_search_categories"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginHorizontal="16dp"
                            android:layout_marginBottom="16dp"
                            android:orientation="horizontal"
                            android:weightSum="4">

                            <!-- Personen-Button -->
                            <LinearLayout
                                android:id="@+id/btn_search_personen"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:gravity="center"
                                android:orientation="vertical">

                                <com.google.android.material.card.MaterialCardView
                                    android:layout_width="50dp"
                                    android:layout_height="50dp"
                                    app:cardBackgroundColor="#FFFFFF"
                                    app:cardCornerRadius="25dp"
                                    app:cardElevation="2dp"
                                    app:strokeWidth="0dp">

                                    <TextView
                                        android:layout_width="match_parent"
                                        android:layout_height="match_parent"
                                        android:gravity="center"
                                        android:text="🧑"
                                        android:textSize="24sp" />
                                </com.google.android.material.card.MaterialCardView>

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="8dp"
                                    android:text="Personen"
                                    android:textColor="#555555"
                                    android:textSize="12sp"
                                    android:textStyle="bold" />
                            </LinearLayout>

                            <!-- Orte-Button -->
                            <LinearLayout
                                android:id="@+id/btn_search_ort"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:gravity="center"
                                android:orientation="vertical">

                                <com.google.android.material.card.MaterialCardView
                                    android:layout_width="50dp"
                                    android:layout_height="50dp"
                                    app:cardBackgroundColor="#FFFFFF"
                                    app:cardCornerRadius="25dp"
                                    app:cardElevation="2dp"
                                    app:strokeWidth="0dp">

                                    <TextView
                                        android:layout_width="match_parent"
                                        android:layout_height="match_parent"
                                        android:gravity="center"
                                        android:text="📍"
                                        android:textSize="24sp" />
                                </com.google.android.material.card.MaterialCardView>

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="8dp"
                                    android:text="Orte"
                                    android:textColor="#555555"
                                    android:textSize="12sp"
                                    android:textStyle="bold" />
                            </LinearLayout>

                            <!-- Datum-Button -->
                            <LinearLayout
                                android:id="@+id/btn_search_datum"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:gravity="center"
                                android:orientation="vertical">

                                <com.google.android.material.card.MaterialCardView
                                    android:layout_width="50dp"
                                    android:layout_height="50dp"
                                    app:cardBackgroundColor="#FFFFFF"
                                    app:cardCornerRadius="25dp"
                                    app:cardElevation="2dp"
                                    app:strokeWidth="0dp">

                                    <TextView
                                        android:layout_width="match_parent"
                                        android:layout_height="match_parent"
                                        android:gravity="center"
                                        android:text="📅"
                                        android:textSize="24sp" />
                                </com.google.android.material.card.MaterialCardView>

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="8dp"
                                    android:text="Datum"
                                    android:textColor="#555555"
                                    android:textSize="12sp"
                                    android:textStyle="bold" />
                            </LinearLayout>

                            <!-- Medien-Button -->
                            <LinearLayout
                                android:id="@+id/btn_search_medientyp"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:gravity="center"
                                android:orientation="vertical">

                                <com.google.android.material.card.MaterialCardView
                                    android:layout_width="50dp"
                                    android:layout_height="50dp"
                                    app:cardBackgroundColor="#FFFFFF"
                                    app:cardCornerRadius="25dp"
                                    app:cardElevation="2dp"
                                    app:strokeWidth="0dp">

                                    <TextView
                                        android:layout_width="match_parent"
                                        android:layout_height="match_parent"
                                        android:gravity="center"
                                        android:text="🎞️"
                                        android:textSize="24sp" />
                                </com.google.android.material.card.MaterialCardView>

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="8dp"
                                    android:text="Medien"
                                    android:textColor="#555555"
                                    android:textSize="12sp"
                                    android:textStyle="bold" />
                            </LinearLayout>
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/layout_search_bottom_buttons"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginHorizontal="16dp"
                            android:orientation="vertical">

                            <TextView android:id="@+id/btn_search_recent" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="8dp" android:background="@drawable/bg_pill_selected" android:backgroundTint="#FFFFFF" android:elevation="2dp" android:padding="16dp" android:text="🕒   Kürzlich aufgenommen" android:textColor="#333333" android:textSize="16sp" android:textStyle="bold" />
                            <TextView android:id="@+id/btn_search_videos" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="8dp" android:background="@drawable/bg_pill_selected" android:backgroundTint="#FFFFFF" android:elevation="2dp" android:padding="16dp" android:text="🎥   Videos" android:textColor="#333333" android:textSize="16sp" android:textStyle="bold" />
                            <TextView android:id="@+id/btn_search_kamera" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="8dp" android:background="@drawable/bg_pill_selected" android:backgroundTint="#FFFFFF" android:elevation="2dp" android:padding="16dp" android:text="📷   Nach Kamera filtern" android:textColor="#333333" android:textSize="16sp" android:textStyle="bold" />
                            <TextView android:id="@+id/btn_search_einstellungen" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="8dp" android:background="@drawable/bg_pill_selected" android:backgroundTint="#FFFFFF" android:elevation="2dp" android:padding="16dp" android:text="⚙️   Such-Einstellungen" android:textColor="#333333" android:textSize="16sp" android:textStyle="bold" />
                        </LinearLayout>
                    </LinearLayout>
                </ScrollView>
            </LinearLayout>

            <!-- 3. ALBEN -->
            <LinearLayout
                android:id="@+id/layout_albums"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:visibility="gone">

                <EditText android:id="@+id/et_album_search" android:layout_width="match_parent" android:layout_height="50dp" android:layout_margin="16dp" android:background="@drawable/bg_pill_selected" android:backgroundTint="#FFFFFF" android:elevation="2dp" android:hint="🔍 Album suchen..." android:inputType="text" android:paddingHorizontal="16dp" android:textColor="#333333" android:textColorHint="#888888" />
                <TextView android:id="@+id/tv_albums_loading" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="32dp" android:text="Lade Alben..." android:textAlignment="center" android:textColor="#888888" android:visibility="gone" />
                <androidx.recyclerview.widget.RecyclerView android:id="@+id/recycler_view_albums" android:layout_width="match_parent" android:layout_height="match_parent" android:clipToPadding="false" android:paddingHorizontal="8dp" android:paddingBottom="100dp" />
            </LinearLayout>

            <!-- 4. BIBLIOTHEK -->
            <androidx.core.widget.NestedScrollView
                android:id="@+id/layout_library"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:paddingBottom="100dp">

                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="24dp" android:text="Bibliothek" android:textColor="#333333" android:textSize="28sp" android:textStyle="bold" />
                    <TextView android:id="@+id/btn_search_favorites" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="8dp" android:background="@drawable/bg_pill_selected" android:backgroundTint="#FFFFFF" android:elevation="2dp" android:padding="16dp" android:text="❤️   Favoriten" android:textColor="#333333" android:textSize="16sp" android:textStyle="bold" />
                    <TextView android:id="@+id/btn_search_archive" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="8dp" android:background="@drawable/bg_pill_selected" android:backgroundTint="#FFFFFF" android:elevation="2dp" android:padding="16dp" android:text="🗃️   Archiv" android:textColor="#333333" android:textSize="16sp" android:textStyle="bold" />
                    <TextView android:id="@+id/btn_search_locked" android:layout_width="match_parent" android:layout_height="wrap_content" android:background="@drawable/bg_pill_selected" android:backgroundTint="#FFFFFF" android:elevation="2dp" android:padding="16dp" android:text="🔒   Gesperrter Ordner (Tresor)" android:textColor="#333333" android:textSize="16sp" android:textStyle="bold" />
                </LinearLayout>
            </androidx.core.widget.NestedScrollView>

            <TextView
                android:id="@+id/tv_fotos_placeholder"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="Lade Bilder..."
                android:textColor="#888888"
                android:visibility="gone" />
        </FrameLayout>
    </LinearLayout>

    <!-- EBENE 2: Setup Eingabefelder -->
    <ScrollView
        android:id="@+id/layout_fotos_setup"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:visibility="gone"
        android:background="#F5F5F5"
        android:elevation="10dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Fotos konfigurieren" android:textSize="28sp" android:textStyle="bold" android:textColor="#333333" android:layout_marginBottom="8dp" android:layout_marginTop="32dp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Verbinde hier deine private Immich Cloud." android:textColor="#666666" android:layout_marginBottom="24dp"/>

            <com.google.android.material.card.MaterialCardView android:layout_width="match_parent" android:layout_height="wrap_content" app:cardCornerRadius="16dp" app:cardElevation="2dp" app:cardBackgroundColor="@android:color/white">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">

                    <EditText android:id="@+id/et_setup_fotos_local" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Lokale URL (http://192...)" android:textColorHint="#888888" android:textColor="#333333" android:padding="12dp" android:background="@drawable/bg_pill_selected" android:backgroundTint="#F0F0F0" android:layout_marginBottom="8dp"/>
                    <EditText android:id="@+id/et_setup_fotos_public" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Public URL (Tailscale etc.)" android:textColorHint="#888888" android:textColor="#333333" android:padding="12dp" android:background="@drawable/bg_pill_selected" android:backgroundTint="#F0F0F0" android:layout_marginBottom="8dp"/>
                    <EditText android:id="@+id/et_setup_fotos_api_key" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Dein Immich API-Key" android:textColorHint="#888888" android:textColor="#333333" android:inputType="textPassword" android:padding="12dp" android:background="@drawable/bg_pill_selected" android:backgroundTint="#F0F0F0" android:layout_marginBottom="24dp"/>

                    <com.google.android.material.button.MaterialButton android:id="@+id/btn_fotos_setup_save" android:layout_width="match_parent" android:layout_height="60dp" android:text="Speichern &amp; Weiter ➡️" android:textColor="@android:color/white" app:backgroundTint="#F49AC2" app:cornerRadius="30dp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
            <View android:layout_width="match_parent" android:layout_height="60dp"/>
        </LinearLayout>
    </ScrollView>

    <!-- EBENE 3: Abgedunkeltes Overlay (Sprechblase) -->
    <FrameLayout
        android:id="@+id/layout_fotos_intro_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#B3000000"
        android:visibility="gone"
        android:padding="24dp"
        android:elevation="20dp">

        <com.google.android.material.card.MaterialCardView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_gravity="center" app:cardCornerRadius="24dp" app:cardElevation="8dp" app:cardBackgroundColor="@android:color/white">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="24dp" android:gravity="center">

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="☁️" android:textSize="48sp" android:layout_marginBottom="16dp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Deine Fotos" android:textSize="24sp" android:textStyle="bold" android:textColor="#333333" android:layout_marginBottom="12dp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Hier landen deine Bilder sicher auf deinem eigenen Server. Gib kurz deine URL und den Key ein." android:textColor="#555555" android:textSize="16sp" android:textAlignment="center" android:layout_marginBottom="32dp"/>

                <com.google.android.material.button.MaterialButton android:id="@+id/btn_fotos_intro_next" android:layout_width="match_parent" android:layout_height="56dp" android:text="Einrichten ➡️" android:textColor="@android:color/white" app:backgroundTint="#F49AC2" app:cornerRadius="28dp" android:layout_marginBottom="12dp"/>
                <com.google.android.material.button.MaterialButton android:id="@+id/btn_fotos_intro_skip" android:layout_width="match_parent" android:layout_height="56dp" android:text="Nicht benötigt (Ausblenden)" android:textColor="#888888" app:backgroundTint="@android:color/transparent" app:strokeColor="#DDDDDD" app:strokeWidth="1dp" app:cornerRadius="28dp"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </FrameLayout>

    <!-- Unten: Auswahl-Leiste (Mehrfachauswahl) -->
    <LinearLayout
        android:id="@+id/layout_selection_bottom_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="horizontal"
        android:gravity="center"
        android:padding="16dp"
        android:background="#FFFFFF"
        android:elevation="8dp"
        android:visibility="gone">

        <ImageView android:id="@+id/btn_selection_share" android:layout_width="24dp" android:layout_height="24dp" android:src="@android:drawable/ic_menu_share" app:tint="#555555" android:layout_weight="1"/>
        <ImageView android:id="@+id/btn_selection_add_to" android:layout_width="24dp" android:layout_height="24dp" android:src="@android:drawable/ic_menu_add" app:tint="#555555" android:layout_weight="1"/>
        <ImageView android:id="@+id/btn_selection_delete" android:layout_width="24dp" android:layout_height="24dp" android:src="@android:drawable/ic_menu_delete" app:tint="#555555" android:layout_weight="1"/>
    </LinearLayout>

    <!-- Fullscreen Overlay -->
    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:id="@+id/fullscreen_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"
        android:elevation="10dp"
        android:background="#000000">

        <androidx.viewpager2.widget.ViewPager2
            android:id="@+id/view_pager_fullscreen"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <!-- Obere Leiste mit Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="end|center_vertical"
            android:padding="16dp"
            android:layout_gravity="top"
            android:background="#40000000">

            <TextView
                android:id="@+id/btn_close_fullscreen"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="✕"
                android:textSize="24sp"
                android:textColor="#FFFFFF"
                android:padding="8dp"
                android:layout_weight="1" />

            <ImageView android:id="@+id/btn_favorite" android:layout_width="28dp" android:layout_height="28dp" android:src="@android:drawable/btn_star" app:tint="#FFFFFF" android:layout_marginEnd="16dp" />
            <ImageView android:id="@+id/btn_more_options" android:layout_width="28dp" android:layout_height="28dp" android:src="@android:drawable/ic_menu_more" app:tint="#FFFFFF" />
        </LinearLayout>

        <!-- Unten: Kleines Menü zum Hochwischen -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:padding="16dp"
            android:layout_gravity="bottom"
            android:background="#40000000">

            <ImageView android:id="@+id/btn_share" android:layout_width="24dp" android:layout_height="24dp" android:src="@android:drawable/ic_menu_share" app:tint="#FFFFFF" android:layout_weight="1"/>
            <ImageView android:id="@+id/btn_edit" android:layout_width="24dp" android:layout_height="24dp" android:src="@android:drawable/ic_menu_edit" app:tint="#FFFFFF" android:layout_weight="1"/>
            <ImageView android:id="@+id/btn_add_to" android:layout_width="24dp" android:layout_height="24dp" android:src="@android:drawable/ic_menu_add" app:tint="#FFFFFF" android:layout_weight="1"/>
            <ImageView android:id="@+id/btn_delete" android:layout_width="24dp" android:layout_height="24dp" android:src="@android:drawable/ic_menu_delete" app:tint="#FFFFFF" android:layout_weight="1"/>
        </LinearLayout>

        <!-- Das große Bottom Sheet mit Meta-Daten -->
        <LinearLayout
            android:id="@+id/bottom_sheet_details"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:background="@drawable/bg_bottom_sheet"
            app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior"
            app:behavior_hideable="true"
            app:behavior_peekHeight="300dp"
            android:padding="24dp"
            android:elevation="16dp">

            <View android:layout_width="40dp" android:layout_height="4dp" android:background="#80FFFFFF" android:layout_gravity="center_horizontal" android:layout_marginBottom="16dp"/>

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Bild-Details" android:textSize="20sp" android:textColor="#333333" android:textStyle="bold" android:layout_marginBottom="24dp"/>

            <EditText android:id="@+id/et_detail_description" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Beschreibung hinzufügen..." android:textColor="#333333" android:textColorHint="#888888" android:background="@android:color/transparent" android:textSize="16sp" android:layout_marginBottom="24dp"/>

            <TextView android:id="@+id/tv_detail_date" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Datum" android:textColor="#555555" android:textSize="14sp" android:layout_marginBottom="16dp" android:drawablePadding="8dp"/>
            <TextView android:id="@+id/tv_detail_location" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Ort" android:textColor="#555555" android:textSize="14sp" android:layout_marginBottom="16dp" android:drawablePadding="8dp"/>
            <TextView android:id="@+id/tv_detail_camera" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Kamera" android:textColor="#555555" android:textSize="14sp" android:layout_marginBottom="16dp" android:drawablePadding="8dp"/>
            <TextView android:id="@+id/tv_detail_filename" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Dateiname" android:textColor="#888888" android:textSize="12sp"/>

        </LinearLayout>
    </androidx.coordinatorlayout.widget.CoordinatorLayout>
</androidx.coordinatorlayout.widget.CoordinatorLayout>