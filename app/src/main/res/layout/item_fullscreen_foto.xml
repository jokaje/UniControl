<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FF000000">

    <!-- Das zoombare Bild -->
    <com.github.chrisbanes.photoview.PhotoView
        android:id="@+id/image_fullscreen_item"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- NEU: Media3 PlayerView ersetzt den alten VideoView -->
    <!-- app:use_controller="false" schaltet die normale Play/Pause Leiste ab -->
    <androidx.media3.ui.PlayerView
        android:id="@+id/video_fullscreen_item"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_gravity="center"
        android:visibility="gone"
        app:use_controller="false"
        app:resize_mode="fit" />

    <!-- Der große Play-Button für die Mitte (wird in Stories versteckt) -->
    <ImageView
        android:id="@+id/btn_play_fullscreen_video"
        android:layout_width="72dp"
        android:layout_height="72dp"
        android:layout_gravity="center"
        android:src="@android:drawable/ic_media_play"
        app:tint="#FFFFFF"
        android:background="@drawable/bg_pill_selected"
        android:backgroundTint="#80000000"
        android:padding="16dp"
        android:visibility="gone" />

</FrameLayout>