<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <!-- EBENE 1: Die normale Chat-UI (Wird im Onboarding versteckt) -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layout_echo_chat"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone">

        <LinearLayout
            android:id="@+id/statusLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="12dp"
            android:paddingBottom="8dp"
            android:background="#F5F5F5"
            android:elevation="2dp"
            app:layout_constraintTop_toTopOf="parent">

            <View
                android:id="@+id/statusIndicator"
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:background="@drawable/bg_pill_selected" />

            <TextView
                android:id="@+id/statusText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="Verbinde..."
                android:textStyle="bold"
                android:textSize="12sp"
                android:textColor="#888888" />
        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/chatRecyclerView"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:padding="8dp"
            android:clipToPadding="false"
            app:layout_constraintTop_toBottomOf="@+id/statusLayout"
            app:layout_constraintBottom_toTopOf="@+id/attachmentPreviewLayout"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <RelativeLayout
            android:id="@+id/attachmentPreviewLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="8dp"
            android:visibility="gone"
            android:background="#E0E0E0"
            app:layout_constraintBottom_toTopOf="@+id/inputLayout">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="100dp"
                android:layout_height="100dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp">
                <ImageView
                    android:id="@+id/attachmentPreviewImage"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:background="#CCCCCC"/>
            </com.google.android.material.card.MaterialCardView>

            <ImageButton
                android:id="@+id/removeAttachmentButton"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginStart="84dp"
                android:layout_marginTop="-8dp"
                android:src="@android:drawable/ic_menu_close_clear_cancel"
                android:background="@drawable/bg_pill_selected"
                android:backgroundTint="#88000000"
                app:tint="@android:color/white"
                android:elevation="4dp"/>
        </RelativeLayout>

        <LinearLayout
            android:id="@+id/inputLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="bottom"
            android:padding="8dp"
            android:background="@android:color/white"
            android:elevation="4dp"
            app:layout_constraintBottom_toBottomOf="parent">

            <ImageButton
                android:id="@+id/attachButton"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_menu_add"
                app:tint="#888888" />

            <EditText
                android:id="@+id/messageEditText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Frag OpenClaw etwas..."
                android:background="@null"
                android:padding="12dp"
                android:inputType="textMultiLine"
                android:maxLines="4" />

            <ImageButton
                android:id="@+id/sendButton"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_btn_speak_now" />
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- EBENE 2: Setup Eingabefelder -->
    <ScrollView
        android:id="@+id/layout_echo_setup"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:visibility="gone"
        android:background="#F5F5F5">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Echo konfigurieren"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="#333333"
                android:layout_marginBottom="8dp"
                android:layout_marginTop="32dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Bitte trage die Verbindungsdaten zu deinem OpenClaw Server ein."
                android:textColor="#666666"
                android:layout_marginBottom="24dp"/>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@android:color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Server URLs" android:textStyle="bold" android:textColor="#333333" android:layout_marginBottom="8dp"/>
                    <EditText android:id="@+id/et_setup_echo_local" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Lokale URL (z.B. wss://192...)" android:padding="12dp" android:background="@drawable/bg_pill_selected" android:backgroundTint="#F0F0F0" android:layout_marginBottom="8dp"/>
                    <EditText android:id="@+id/et_setup_echo_public" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Public URL (z.B. wss://tailscale...)" android:padding="12dp" android:background="@drawable/bg_pill_selected" android:backgroundTint="#F0F0F0" android:layout_marginBottom="16dp"/>

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Sicherheit &amp; Identität" android:textStyle="bold" android:textColor="#333333" android:layout_marginBottom="8dp"/>
                    <EditText android:id="@+id/et_setup_echo_pass" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="OpenClaw Passwort" android:inputType="textPassword" android:padding="12dp" android:background="@drawable/bg_pill_selected" android:backgroundTint="#F0F0F0" android:layout_marginBottom="8dp"/>
                    <EditText android:id="@+id/et_setup_device_id" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Device ID (z.B. uni-control-1)" android:padding="12dp" android:background="@drawable/bg_pill_selected" android:backgroundTint="#F0F0F0" android:layout_marginBottom="8dp"/>
                    <EditText android:id="@+id/et_setup_pub_key" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Public Key (Base64)" android:padding="12dp" android:background="@drawable/bg_pill_selected" android:backgroundTint="#F0F0F0" android:layout_marginBottom="8dp"/>
                    <EditText android:id="@+id/et_setup_priv_key" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Private Key (Base64)" android:inputType="textPassword" android:padding="12dp" android:background="@drawable/bg_pill_selected" android:backgroundTint="#F0F0F0" android:layout_marginBottom="24dp"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_setup_save"
                        android:layout_width="match_parent"
                        android:layout_height="60dp"
                        android:text="Speichern &amp; Weiter ➡️"
                        android:textColor="@android:color/white"
                        app:backgroundTint="#AEC6CF"
                        app:cornerRadius="30dp"/>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
            <View android:layout_width="match_parent" android:layout_height="60dp"/>
        </LinearLayout>
    </ScrollView>

    <!-- EBENE 3: Abgedunkeltes Overlay (Sprechblase) -->
    <FrameLayout
        android:id="@+id/layout_echo_intro_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#B3000000"
        android:visibility="gone"
        android:padding="24dp">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            app:cardCornerRadius="24dp"
            app:cardElevation="8dp"
            app:cardBackgroundColor="@android:color/white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="💬"
                    android:textSize="48sp"
                    android:layout_marginBottom="16dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Dein KI-Agent"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:textColor="#333333"
                    android:layout_marginBottom="12dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Hier wohnt Echo, dein persönlicher OpenClaw Assistent.\n\nDamit er mit dir sprechen kann, benötigt er einmalig deine Server-Verbindung und Schlüssel zur Authentifizierung."
                    android:textColor="#555555"
                    android:textSize="16sp"
                    android:textAlignment="center"
                    android:lineSpacingExtra="4dp"
                    android:layout_marginBottom="32dp"/>

                <!-- NEU: Zwei Buttons zur Auswahl -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_intro_next"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="Einrichten ➡️"
                    android:textColor="@android:color/white"
                    app:backgroundTint="#AEC6CF"
                    app:cornerRadius="28dp"
                    android:layout_marginBottom="12dp"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_intro_skip"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="Nicht benötigt (Ausblenden)"
                    android:textColor="#888888"
                    app:backgroundTint="@android:color/transparent"
                    app:strokeColor="#DDDDDD"
                    app:strokeWidth="1dp"
                    app:cornerRadius="28dp"/>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </FrameLayout>

</FrameLayout>