<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:padding="6dp">

    <!-- Größere Hochkante Karte (140x220) mit 16dp abgerundeten Ecken -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="140dp"
        android:layout_height="220dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="3dp"
        app:strokeWidth="0dp">

        <ImageView
            android:id="@+id/iv_memory_cover"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"/>

        <!-- Der Schatten-Verlauf, der nur unten über dem Bild liegt -->
        <View
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:layout_gravity="bottom"
            android:background="@drawable/bg_memory_gradient" />

        <TextView
            android:id="@+id/tv_memory_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:padding="12dp"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:gravity="bottom|start"
            android:maxLines="3"
            android:ellipsize="end"
            android:shadowColor="#80000000"
            android:shadowDx="1"
            android:shadowDy="1"
            android:shadowRadius="3"
            android:text="Vor 1 Jahr"/>

    </com.google.android.material.card.MaterialCardView>
</LinearLayout>